<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dph.App.ViewModels"
        xmlns:domain="using:Dph.Core.Domain"
        xmlns:epo="using:Dph.Core.Epo"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1240"
        d:DesignHeight="760"
        Width="1240"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        x:Class="Dph.App.Views.MainWindow"
        Name="mainWindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/dph-asistent.ico"
        Title="DPH Asistent">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,* ,Auto" Background="#F4F6F8">
        <Border Grid.Row="0" Background="#1F2937" Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Text="DPH Asistent" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding SummaryText}" Foreground="#D1D5DB" Margin="18,0,0,0" VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Command="{Binding CopyAmountToPayCommand}"
                        Background="#F59E0B"
                        Foreground="#1F2937"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,5"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="Klikni pro zkopírování částky k zaplacení do schránky">
                    <TextBlock Text="{Binding AmountToPayText}" FontWeight="Bold" FontSize="14"/>
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#FBBF24"/>
                            <Setter Property="TextElement.Foreground" Value="#1F2937"/>
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter">
                            <Setter Property="Background" Value="#D97706"/>
                            <Setter Property="TextElement.Foreground" Value="#1F2937"/>
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Grid.Column="3"
                        Command="{Binding ExportXmlCommand}"
                        Content="Export XML"
                        Background="#F9FAFB"
                        Foreground="#111827"
                        BorderBrush="#CBD5E1"
                        Padding="14,6">
                    <Button.Styles>
                        <!-- Bez explicitního pointerover/pressed by se na tmavé liště tlačítko ztratilo. -->
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#E5E7EB"/>
                            <Setter Property="TextElement.Foreground" Value="#111827"/>
                            <Setter Property="BorderBrush" Value="#9CA3AF"/>
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter">
                            <Setter Property="Background" Value="#D1D5DB"/>
                            <Setter Property="TextElement.Foreground" Value="#111827"/>
                            <Setter Property="BorderBrush" Value="#9CA3AF"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Přiznání">
                <Grid ColumnDefinitions="220,*" ColumnSpacing="10">
                    <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                            <TextBlock Text="Období" FontSize="15" FontWeight="SemiBold"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="domain:VatPeriod">
                                        <TextBlock Text="{Binding Label}" Padding="6"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="6">
                                <Button Command="{Binding AddPeriodCommand}" Content="Nové z vybraného" HorizontalAlignment="Stretch"/>
                                <Button Grid.Row="1" Command="{Binding DeleteSelectedPeriodCommand}" Content="Smazat období" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" RowDefinitions="Auto,* ,Auto" RowSpacing="10">
                        <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="10">
                            <Grid ColumnDefinitions="110,120,90,120,90,120,100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <TextBlock Text="DIČ" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding TaxSubject.Dic}"/>
                                <TextBlock Grid.Column="2" Text="Jméno" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding TaxSubject.FirstName}"/>
                                <TextBlock Grid.Column="4" Text="Příjmení" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="5" Text="{Binding TaxSubject.LastName}"/>
                                <TextBlock Grid.Column="6" Text="E-mail" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="7" Text="{Binding TaxSubject.Email}"/>

                                <TextBlock Grid.Row="1" Text="Ulice" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TaxSubject.Street}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Č.p." VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TaxSubject.HouseNumber}"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="Obec" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding TaxSubject.City}"/>
                                <TextBlock Grid.Row="1" Grid.Column="6" Text="PSČ" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="7" Text="{Binding TaxSubject.PostalCode}"/>

                                <TextBlock Grid.Row="2" Text="Fin. úřad" VerticalAlignment="Center"
                                           ToolTip.Tip="Cílový finanční úřad (c_ufo). Doplní se z ARES, nebo vyber ze seznamu."/>
                                <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding TaxOffices}"
                                          SelectedItem="{Binding SelectedTaxOffice}"
                                          DropDownOpened="OnTaxOfficeDropDownOpened">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="epo:TaxOffice">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Grid.Column="4" Text="Úz. prac." VerticalAlignment="Center"
                                           ToolTip.Tip="Územní pracoviště (c_pracufo) – seznam podle vybraného finančního úřadu."/>
                                <ComboBox Grid.Row="2" Grid.Column="5" Grid.ColumnSpan="3"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableWorkplaces}"
                                          SelectedItem="{Binding SelectedWorkplace}"
                                          DropDownOpened="OnTaxOfficeDropDownOpened">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="epo:TaxOfficeWorkplace">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Text="IČO" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TaxSubject.Ico}"/>
                                <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                        Command="{Binding FillTaxSubjectFromAresCommand}"
                                        Content="Doplnit z ARES"
                                        HorizontalAlignment="Left"
                                        ToolTip.Tip="Podle IČO (nebo DIČ právnické osoby) doplní z ARES prázdné údaje poplatníka včetně cílového finančního úřadu (c_ufo)."/>
                                <TextBlock Grid.Row="3" Grid.Column="4" Text="Telefon" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="5" Text="{Binding TaxSubject.Phone}"/>
                                <TextBlock Grid.Row="3" Grid.Column="6" Text="Datová schr." VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="7" Text="{Binding TaxSubject.DataBoxId}"/>

                                <TextBlock Grid.Row="4" Text="Bankovní účet" VerticalAlignment="Center"
                                           ToolTip.Tip="Účet dodavatele pro vydané faktury ve tvaru [předčíslí-]číslo/kód banky. Z něj se počítá IBAN a QR Platba."/>
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding BankAccount}"/>
                                <TextBlock Grid.Row="4" Grid.Column="4" Text="IBAN" VerticalAlignment="Center"
                                           ToolTip.Tip="Dopočítá se z bankovního účtu. Přepiš jen u zahraničního účtu."/>
                                <TextBox Grid.Row="4" Grid.Column="5" Grid.ColumnSpan="3" Text="{Binding Iban}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="10">
                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <TextBlock Text="Faktury" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding AddInvoiceCommand}" Content="Přidat"/>
                                    <Button Grid.Column="2" Command="{Binding DeleteSelectedInvoiceCommand}" Content="Smazat"/>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="145,180,110,115,100,90,70,90,70,58,80,90,*" ColumnSpacing="6">
                                    <TextBlock Text="Typ"/>
                                    <TextBlock Grid.Column="1" Text="Subjekt"/>
                                    <TextBlock Grid.Column="2" Text="DIČ"/>
                                    <TextBlock Grid.Column="3" Text="Doklad"/>
                                    <TextBlock Grid.Column="4" Text="DUZP"/>
                                    <TextBlock Grid.Column="5" Text="Základ"/>
                                    <TextBlock Grid.Column="6" Text="DPH"/>
                                    <TextBlock Grid.Column="7" Text="S DPH"/>
                                    <TextBlock Grid.Column="8" Text="Sazba"/>
                                    <TextBlock Grid.Column="9" Text="Část."/>
                                    <TextBlock Grid.Column="10" Text="Měna"/>
                                    <TextBlock Grid.Column="11" Text="Cizí částka"/>
                                    <TextBlock Grid.Column="12" Text="Poznámka"/>
                                </Grid>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding Invoices}"
                                         SelectedItem="{Binding SelectedInvoice}"
                                         Padding="0"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InvoiceLineViewModel">
                                            <Grid ColumnDefinitions="145,180,110,115,100,90,70,90,70,58,80,90,*" ColumnSpacing="6" Margin="0,2">
                                                <ComboBox ItemsSource="{Binding KindOptions}" SelectedItem="{Binding Kind}" MinWidth="135"/>
                                                <Grid Grid.Column="1" ColumnDefinitions="*,34" ColumnSpacing="4">
                                                    <TextBox Text="{Binding CounterpartyName, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{Binding #mainWindowRoot.((vm:MainWindowViewModel)DataContext).Counterparties}"
                                                              SelectedItem="{Binding Counterparty}"
                                                              ToolTip.Tip="Vybrat z adresáře">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:CounterpartyViewModel">
                                                                <TextBlock Text="{Binding DisplayName}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </Grid>
                                                <TextBox Grid.Column="2" Text="{Binding CounterpartyDic, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="3" Text="{Binding EvidenceNumber}"/>
                                                <TextBox Grid.Column="4" Text="{Binding TaxableSupplyDate}"/>
                                                <TextBox Grid.Column="5" Text="{Binding TaxBaseCzk, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="6" Text="{Binding VatCzk, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="7" Text="{Binding GrossCzk, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ComboBox Grid.Column="8" ItemsSource="{Binding VatRateOptions}" SelectedItem="{Binding VatRate}"/>
                                                <!-- Tooltip na wrapperu: disablovaný CheckBox nepřijímá pointer eventy, takže ToolTip.Tip
                                                     na něm samotném by se nikdy nezobrazil. Wrapper zůstává enabled. -->
                                                <Border Grid.Column="9"
                                                        IsVisible="{Binding ShowPartialDeduction}"
                                                        ToolTip.Tip="{Binding PartialDeductionTooltip}"
                                                        Background="Transparent"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <CheckBox IsChecked="{Binding PartialDeduction}"
                                                              IsEnabled="{Binding IsPartialDeductionEditorEnabled}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBox Grid.Column="10" Text="{Binding Currency}"/>
                                                <TextBox Grid.Column="11" Text="{Binding ForeignAmount}"/>
                                                <TextBox Grid.Column="12" Text="{Binding Note}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Button Command="{Binding ApplyCnbRateCommand}" Content="Kurz ČNB pro vybranou fakturu"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Vydané faktury">
                <Grid Name="issuedInvoicesRoot" DataContext="{Binding Issuing}" x:DataType="vm:IssuedInvoicesViewModel" ColumnDefinitions="300,*" ColumnSpacing="10">
                    <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                            <TextBlock Text="Vydané faktury" FontSize="15" FontWeight="SemiBold"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding Invoices}" SelectedItem="{Binding SelectedInvoice}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:IssuedInvoiceViewModel">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TotalsText}" Foreground="#6B7280" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <Button Command="{Binding NewInvoiceCommand}" Content="Nová faktura" HorizontalAlignment="Stretch"/>
                                <Button Grid.Row="1" Command="{Binding UseAsTemplateCommand}" Content="Použít jako šablonu" HorizontalAlignment="Stretch"/>
                                <Button Grid.Row="2" Command="{Binding DeleteInvoiceCommand}" Content="Smazat fakturu" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="14"
                            IsVisible="{Binding SelectedInvoice, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ScrollViewer>
                            <StackPanel Spacing="10" DataContext="{Binding SelectedInvoice}" x:DataType="vm:IssuedInvoiceViewModel">
                                <Grid ColumnDefinitions="90,150,90,140,90,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                    <TextBlock Text="Číslo" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Number}"/>
                                    <TextBlock Grid.Column="2" Text="Vystaveno" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="3" Text="{Binding IssueDate}"/>
                                    <TextBlock Grid.Column="4" Text="DUZP" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="5" Text="{Binding TaxableSupplyDate}" HorizontalAlignment="Left" MinWidth="140"/>

                                    <TextBlock Grid.Row="1" Text="Splatnost" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DueDate}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Var. symbol" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding VariableSymbol}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Měna" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding Currency}" HorizontalAlignment="Left" MinWidth="80"/>
                                </Grid>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="10">
                                    <Grid ColumnDefinitions="90,160,Auto,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                        <TextBlock Text="Odběratel" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding CustomerIco}" Watermark="IČO"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext).FillCustomerFromAresCommand}"
                                                Content="Načíst z ARES"/>
                                        <ComboBox Grid.Column="3"
                                                  MinWidth="200"
                                                  PlaceholderText="…nebo z adresáře"
                                                  ItemsSource="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext).Customers}"
                                                  SelectedItem="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext).SelectedCustomer}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CounterpartyViewModel">
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Text="Název" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding CustomerName}"/>

                                        <TextBlock Grid.Row="2" Text="DIČ" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CustomerDic}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Ulice / č.p." VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        <Grid Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" ColumnDefinitions="*,80" ColumnSpacing="6">
                                            <TextBox Text="{Binding CustomerStreet}"/>
                                            <TextBox Grid.Column="1" Text="{Binding CustomerHouseNumber}"/>
                                        </Grid>

                                        <TextBlock Grid.Row="3" Text="Obec / PSČ" VerticalAlignment="Center"/>
                                        <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,90" ColumnSpacing="6">
                                            <TextBox Text="{Binding CustomerCity}"/>
                                            <TextBox Grid.Column="1" Text="{Binding CustomerPostalCode}"/>
                                        </Grid>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Stát" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        <TextBox Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" Text="{Binding CustomerCountry}"/>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                                    <TextBlock Text="Úvodní text" VerticalAlignment="Center"
                                               ToolTip.Tip="Text nad položkami. Placeholdery {měsíc} a {rok} se v PDF nahradí podle DUZP (např. 'Za {měsíc} {rok} Vám fakturujeme:'). Předvyplní se při vystavení v poslední den měsíce."/>
                                    <TextBox Grid.Column="1" Text="{Binding IntroText}"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Text="Položky" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Command="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext).AddItemCommand}"
                                            Content="Přidat řádek"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,64,52,98,76,104,92,40" ColumnSpacing="10">
                                    <TextBlock Text="Popis"/>
                                    <TextBlock Grid.Column="1" Text="Počet" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="MJ"/>
                                    <TextBlock Grid.Column="3" Text="Cena/MJ" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="Sazba" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Základ" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="6" Text="DPH" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="7" Text=""/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:IssuedInvoiceItemViewModel">
                                            <Grid ColumnDefinitions="*,64,52,98,76,104,92,40" ColumnSpacing="10" Margin="0,2">
                                                <TextBox Text="{Binding Description}"/>
                                                <TextBox Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="2" Text="{Binding Unit}"/>
                                                <TextBox Grid.Column="3" Text="{Binding UnitPriceCzk, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ComboBox Grid.Column="4" ItemsSource="{Binding VatRateOptions}" SelectedItem="{Binding VatRate}"/>
                                                <TextBlock Grid.Column="5" Text="{Binding LineBaseText}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="6" Text="{Binding LineVatText}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                                                <Button Grid.Column="7" Content="✕"
                                                        Command="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext).RemoveItemCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding TotalsText}" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                    <TextBlock Text="Poznámka" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Note}"/>
                                    <TextBlock Grid.Row="1" Text="Patička" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Footer}"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right"
                                            DataContext="{Binding #issuedInvoicesRoot.((vm:IssuedInvoicesViewModel)DataContext)}"
                                            x:DataType="vm:IssuedInvoicesViewModel">
                                    <Button Command="{Binding InsertIntoVatCommand}" Content="Vložit do DPH"/>
                                    <Button Command="{Binding SavePdfCommand}" Content="Uložit PDF"
                                            Background="#2563EB" Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Subjekty">
                <Grid ColumnDefinitions="320,*" ColumnSpacing="10">
                    <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                            <TextBlock Text="Adresář" FontSize="15" FontWeight="SemiBold"/>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Counterparties}"
                                     SelectedItem="{Binding SelectedCounterparty, Mode=OneWay}"
                                     SelectionChanged="OnCounterpartySelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CounterpartyViewModel">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Dic}" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Grid.Row="2" Command="{Binding AddCounterpartyCommand}" Content="Přidat subjekt"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="14">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="130,*" ColumnSpacing="10" RowSpacing="10">
                            <TextBlock Text="Název" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SelectedCounterparty.Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="1" Text="IČO" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCounterparty.Ico, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="2" Text="DIČ" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedCounterparty.Dic, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="3" Text="Ulice / č.p." VerticalAlignment="Center"/>
                            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,90" ColumnSpacing="8">
                                <TextBox Text="{Binding SelectedCounterparty.Street, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedCounterparty.HouseNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Grid.Row="4" Text="Obec / PSČ" VerticalAlignment="Center"/>
                            <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,90" ColumnSpacing="8">
                                <TextBox Text="{Binding SelectedCounterparty.City, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="1" Text="{Binding SelectedCounterparty.PostalCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Grid.Row="5" Text="Stát / role" VerticalAlignment="Center"/>
                            <Grid Grid.Row="5" Grid.Column="1" ColumnDefinitions="100,180,*" ColumnSpacing="8">
                                <TextBox Text="{Binding SelectedCounterparty.CountryCode}"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding SelectedCounterparty.RoleOptions}" SelectedItem="{Binding SelectedCounterparty.Role}"/>
                            </Grid>
                            <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Button Command="{Binding FillCounterpartyFromAresCommand}" Content="Doplnit z ARES"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Import">
                <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4" Padding="14">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="130,*" ColumnSpacing="10" RowSpacing="10">
                        <TextBlock Text="Složka XML" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ImportDirectory}"/>
                        <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Command="{Binding ImportXmlDirectoryCommand}" Content="Importovat XML"/>
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Historická XML slouží pouze jako import dat a testovací příklad; EPO je autorita pro export." Foreground="#6B7280"/>
                        <TextBlock Grid.Row="3" Text="Databáze" VerticalAlignment="Center"/>
                        <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                            <Button Command="{Binding BackupDatabaseCommand}" Content="Zálohovat DB"/>
                            <Button Grid.Column="1" Command="{Binding RestoreDatabaseCommand}" Content="Obnovit DB"/>
                        </Grid>
                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="{Binding DatabasePath, StringFormat='Aktuální DB: {0}'}" Foreground="#6B7280"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#E5E7EB" Padding="10,6">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#374151"/>
                <TextBlock Grid.Column="1" Text="{Binding DatabasePath, StringFormat='DB: {0}'}" Foreground="#374151"/>
            </Grid>
        </Border>
    </Grid>
</Window>
